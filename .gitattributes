# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.py   text eol=lf
*.sh   text eol=lf

# Config/Data
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Windows-specific scripts (CRLF 유지)
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary files (변환 금지)
*.zip  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary