ENV=dev

# Safety
DRY_RUN=true
AUTO_EXECUTE=false

# Policy
CONFIDENCE_THRESHOLD=0.72
MAX_BUDGET_DELTA_PCT=20
POLICY_PATH=policies/policy.yml

# Ops
OPS_TOKEN=change-me

# Worker
WORKER_POLL_SECONDS=2
OUTBOX_MAX_RETRIES=5

# Gateway
GATEWAY_PORT=8080
AI_URL=http://ai:8000
CONNECTORS_URL=http://connectors:3000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genie_roi
POSTGRES_USER=genie
POSTGRES_PASSWORD=genie

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
