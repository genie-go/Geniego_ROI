ENV=dev

# Safety
DRY_RUN=true
AUTO_EXECUTE=false

# Policy
CONFIDENCE_THRESHOLD=0.72
MAX_BUDGET_DELTA_PCT=20
POLICY_PATH=policies/policy.yml

# Ops
OPS_TOKEN=change-me

# Worker
WORKER_POLL_SECONDS=2
OUTBOX_MAX_RETRIES=5

# Gateway
GATEWAY_PORT=8080
AI_URL=http://ai:8000
CONNECTORS_URL=http://connectors:3000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genie_roi
POSTGRES_USER=genie
POSTGRES_PASSWORD=genie

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Optional secret file mounts (for rotation)
META_ACCESS_TOKEN_FILE=
NAVER_API_KEY_FILE=
NAVER_SECRET_KEY_FILE=
NAVER_CUSTOMER_ID_FILE=

# --- V163: Multi-tenant / Quotas / API keys ---
GATEWAY_REQUIRE_API_KEY=true
# Bootstrap admin API key (inserted on first start if api_keys table empty)
BOOTSTRAP_ADMIN_API_KEY=admin_dev_key_change_me

# Tenant quota defaults (can be overridden per tenant in DB)
DEFAULT_DAILY_EXEC_LIMIT=200
DEFAULT_PER_MINUTE_LIMIT=60

# --- V163: Experiment framework ---
EXPERIMENT_GUARDRAIL_MAX_DAILY_SPEND=0  # 0 disables spend guardrail
EXPERIMENT_GUARDRAIL_MAX_NEG_UPLIFT_PCT=-10

# --- V265: Google Ads (real integration via HTTP/JSON endpoints) ---
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_BUDGET_RESOURCE_NAMES=customers/123/campaignBudgets/456
GOOGLE_ADS_VALUE_IS_MICROS=false
GOOGLE_ADS_BUDGET_UNIT_MICROS=1000000

# --- V265: TikTok Ads ---
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=
TIKTOK_TARGET_ADGROUP_IDS=
TIKTOK_API_BASE=https://business-api.tiktok.com/open_api/v1.3

# --- V265: Amazon Ads ---
AMAZON_ADS_ACCESS_TOKEN=
AMAZON_ADS_PROFILE_ID=
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CAMPAIGN_IDS=
AMAZON_ADS_API_BASE=https://advertising-api.amazon.com

# --- V265: Shopify Webhooks ---
SHOPIFY_WEBHOOK_SECRET=

# V266: Google Ads second object (campaign status)
GOOGLE_ADS_CAMPAIGN_RESOURCE_NAMES=customers/123/campaigns/456
# Action: {type: set_campaign_status, value: PAUSED}

# V266: Amazon Ads second object (campaign state)
# Action: {type: set_campaign_state, value: paused}

# V266: Experiments (randomization/contamination control)
# Send in /v163/workflows/run body: experiment_id, unit_id (stable), force_variant(optional)
