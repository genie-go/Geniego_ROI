ENV=dev

# Safety
DRY_RUN=true
AUTO_EXECUTE=false

# Policy
CONFIDENCE_THRESHOLD=0.72
MAX_BUDGET_DELTA_PCT=20
POLICY_PATH=policies/policy.yml

# Ops
OPS_TOKEN=change-me

# Worker
WORKER_POLL_SECONDS=2
OUTBOX_MAX_RETRIES=5

# Gateway
GATEWAY_PORT=8080
AI_URL=http://ai:8000
CONNECTORS_URL=http://connectors:3000

# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genie_roi
POSTGRES_USER=genie
POSTGRES_PASSWORD=genie

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Optional secret file mounts (for rotation)
META_ACCESS_TOKEN_FILE=
NAVER_API_KEY_FILE=
NAVER_SECRET_KEY_FILE=
NAVER_CUSTOMER_ID_FILE=

# --- V163: Multi-tenant / Quotas / API keys ---
GATEWAY_REQUIRE_API_KEY=true
# Bootstrap admin API key (inserted on first start if api_keys table empty)
BOOTSTRAP_ADMIN_API_KEY=admin_dev_key_change_me

# Tenant quota defaults (can be overridden per tenant in DB)
DEFAULT_DAILY_EXEC_LIMIT=200
DEFAULT_PER_MINUTE_LIMIT=60

# --- V163: Experiment framework ---
EXPERIMENT_GUARDRAIL_MAX_DAILY_SPEND=0  # 0 disables spend guardrail
EXPERIMENT_GUARDRAIL_MAX_NEG_UPLIFT_PCT=-10
