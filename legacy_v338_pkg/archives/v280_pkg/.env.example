# ---- Common ----
GENIE_ENV=dev
GENIE_TENANT_ID=demo-tenant

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=genie
POSTGRES_USER=genie
POSTGRES_PASSWORD=genie

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- Gateway ----
GATEWAY_PORT=8080
DRY_RUN=true               # Safe mode by default
ENFORCE_POLICIES=true      # Hard-block violations

# ---- AI Engine ----
AI_ENGINE_URL=http://ai_engine:9000

# ---- Connectors ----
CONNECTORS_URL=http://connectors:9100
