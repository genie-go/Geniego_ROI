APP_ENV=local
DATABASE_URL=postgresql+psycopg://genie:genie@localhost:5432/genie
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Execution controls
AUTO_EXECUTE=false
DRY_RUN=true
AUTH_MODE=stub

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Meta
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_
META_API_VERSION=v20.0

# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_ADVERTISER_ID=

# Naver SearchAd (signed requests)
NAVER_API_KEY=
NAVER_SECRET_KEY=
NAVER_CUSTOMER_ID=

# Kakao Moment
KAKAO_ACCESS_TOKEN=
KAKAO_AD_ACCOUNT_ID=
