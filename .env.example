# GeniegoROI Root Environment Example
# DO NOT ADD REAL SECRETS OR PASSWORDS TO THIS FILE
#
# 위치: 저장소 루트. backend/src/Db.php:98 이 __DIR__.'/../../.env' 로 이 경로를 직접 파싱한다
#       (PHP-FPM 이 환경변수를 전달하지 않는 배포 환경 대응).
# 키 이름은 backend/src 가 실제로 읽는 것만 적는다 — grep -rhoE "GENIE_[A-Z0-9_]+" backend/src 로 재확인 가능.
# ★ 미설정 시 Db.php 는 조용히 SQLite(data/genie.sqlite)로 폴백하므로, 오타는 오류가 아니라 무음 폴백으로 나타난다.

# ── 실행 환경 ─────────────────────────────────────────
GENIE_ENV=local

# ── Database (MySQL 주 · 실패 시 SQLite 폴백) ─────────
GENIE_DB_HOST=127.0.0.1
GENIE_DB_PORT=3306
GENIE_DB_NAME=geniego_roi
GENIE_DB_USER=genie_user
GENIE_DB_PASS=replace-with-local-db-password
# 데모 테넌트 전용 DB (운영/데모 격리)
GENIE_DEMO_DB_NAME=geniego_roi_demo

# ── Frontend (vite) ───────────────────────────────────
# 로컬 풀스택 구동 시 dev 프록시 타깃. 미설정 시 frontend/vite.config.js 기본값=운영(https://www.genieroi.com).
VITE_PROXY_TARGET=http://localhost:8080
VITE_API_BASE=http://localhost:8000

# ── 메일 (Postfix/SMTP) ───────────────────────────────
GENIE_SMTP_HOST=127.0.0.1
GENIE_SMTP_PORT=587
GENIE_SMTP_USER=
GENIE_SMTP_PASS=
GENIE_SMTP_SECURE=tls
GENIE_SMTP_FROM=no-reply@genieroi.com
GENIE_SMTP_FROM_NAME=GenieROI
# 로컬 sendmail 로 보낼 때만 1
GENIE_MAIL_USE_SENDMAIL=0

# ── SMS (NAVER SENS) ──────────────────────────────────
GENIE_SMS_SERVICE_ID=
GENIE_SMS_ACCESS_KEY=
GENIE_SMS_SECRET_KEY=
GENIE_SMS_FROM=

# ── SMS 대체 채널 (선택) ──────────────────────────────
GENIE_NHN_APPKEY=
GENIE_NHN_SECRET=
GENIE_NHN_SENDER=
GENIE_TWILIO_SID=
GENIE_TWILIO_TOKEN=
GENIE_TWILIO_FROM=
GENIE_TWILIO_MSG_SID=

# ── Webhook 서명 ──────────────────────────────────────
GENIE_WEBHOOK_SECRET=replace-with-random-32byte-secret

# ── 개발 편의 (운영에서는 반드시 비활성) ──────────────
# 1 이면 OTP 를 실제 발송 없이 통과시킨다. 운영 설정 금지.
GENIE_OTP_DEV=0
