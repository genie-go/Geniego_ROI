# EditorConfig — GeniegoROI
# https://editorconfig.org
# CCIS Part002 — Repository & Monorepo Architecture
# Version 1.0 | 2026-07-22

# Top-most EditorConfig file
root = true

# ─────────────────────────────────────────────────────────────
# All files (기본값)
# ─────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

# ─────────────────────────────────────────────────────────────
# JavaScript / TypeScript / JSX / TSX (Frontend)
# ─────────────────────────────────────────────────────────────
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_size = 2
quote_type = single

# ─────────────────────────────────────────────────────────────
# PHP (Backend)
# ─────────────────────────────────────────────────────────────
[*.php]
indent_size = 4
indent_style = space

# ─────────────────────────────────────────────────────────────
# SQL (Database Migrations)
# ─────────────────────────────────────────────────────────────
[*.sql]
indent_size = 4
indent_style = space

# ─────────────────────────────────────────────────────────────
# JSON / YAML / TOML (Config)
# ─────────────────────────────────────────────────────────────
[*.{json,yaml,yml,toml}]
indent_size = 2

# ─────────────────────────────────────────────────────────────
# Markdown (Documentation)
# ─────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ─────────────────────────────────────────────────────────────
# Shell Scripts
# ─────────────────────────────────────────────────────────────
[*.sh]
end_of_line = lf
indent_size = 2

# ─────────────────────────────────────────────────────────────
# PowerShell (Windows)
# ─────────────────────────────────────────────────────────────
[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4

# ─────────────────────────────────────────────────────────────
# Windows Batch / CMD
# ─────────────────────────────────────────────────────────────
[*.{bat,cmd}]
end_of_line = crlf
indent_size = 4

# ─────────────────────────────────────────────────────────────
# CSS (Frontend Styles)
# ─────────────────────────────────────────────────────────────
[*.{css,scss,less}]
indent_size = 2

# ─────────────────────────────────────────────────────────────
# HTML
# ─────────────────────────────────────────────────────────────
[*.{html,htm}]
indent_size = 2

# ─────────────────────────────────────────────────────────────
# Python (Tools / Scripts)
# ─────────────────────────────────────────────────────────────
[*.py]
indent_size = 4
indent_style = space

# ─────────────────────────────────────────────────────────────
# Makefile (탭 필수)
# ─────────────────────────────────────────────────────────────
[Makefile]
indent_style = tab
indent_size = 4

# ─────────────────────────────────────────────────────────────
# Dockerfile
# ─────────────────────────────────────────────────────────────
[Dockerfile*]
indent_size = 4
