#!/usr/bin/env bash
# .githooks/pre-commit — Session 154 bank-grade safety gate
# Install: git config core.hooksPath .githooks
# Bypass:  git commit --no-verify (requires N-145-G explicit approval)

set -e
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

BASELINE=".githooks/baseline.json"
[ -f "$BASELINE" ] || { echo "❌ pre-commit: $BASELINE missing"; exit 1; }

FAIL=0
warn() { echo "⚠️  $*"; }
fail() { echo "❌ $*"; FAIL=1; }
ok()   { echo "✅ $*"; }

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

# B1 — *.bak* tracking refused
BAK_HITS=$(echo "$STAGED" | grep -E '\.bak[0-9]*(_|$|\.)' || true)
if [ -n "$BAK_HITS" ]; then
  fail "B1: staged backup files (.bak*) — move to _quarantine/ or use .gitignore"
  echo "$BAK_HITS" | sed 's/^/   /'
fi

# B2 — _quarantine/ paths refused
QUAR_HITS=$(echo "$STAGED" | grep -E '(^|/)_quarantine/' || true)
if [ -n "$QUAR_HITS" ]; then
  fail "B2: _quarantine/ paths staged — gitignored by Session 153 policy"
  echo "$QUAR_HITS" | sed 's/^/   /'
fi

# B3 — NEXT_SESSION.md size sanity (between 1KB and 500KB if staged)
if echo "$STAGED" | grep -qx 'NEXT_SESSION.md'; then
  SIZE=$(wc -c < NEXT_SESSION.md)
  if [ "$SIZE" -lt 1024 ] || [ "$SIZE" -gt 512000 ]; then
    fail "B3: NEXT_SESSION.md size out of range ($SIZE bytes; expected 1KB-500KB)"
  else
    ok  "B3: NEXT_SESSION.md size $SIZE bytes (sane)"
  fi
fi

# B4 — secret-shaped patterns in staged diff
#   [289차 ④] 규칙을 tools/scan_secrets.sh 로 이관(SSOT). CI(security-scan.yml)가 **같은 스크립트**를 호출한다.
#   종전엔 정규식이 이 파일에만 있었고 pre-commit 은 로컬 opt-in(hooksPath=클론별 · --no-verify 우회)이라
#   B4 가 사실상 opt-in 이었다. 정규식을 CI 에 복사하면 규칙이 두 벌로 갈라져 따로 낡으므로(289차 ② '351 5벌'과
#   같은 클래스) 호출처를 하나로 둔다. 규칙 변경은 tools/scan_secrets.sh 한 곳만 고치면 양쪽에 반영된다.
#   ★출력은 값을 마스킹한다 — 유출을 잡는 도구가 로그로 유출하면 안 된다.
if ! bash tools/scan_secrets.sh --staged; then
  fail "B4: secret-shaped lines added to staging"
fi

# G2 — Sacred SHA check (ja.js, zh.js)
JA_EXPECT=$(node -e "console.log(require('./$BASELINE').sacred_sha['ja.js'])")
ZH_EXPECT=$(node -e "console.log(require('./$BASELINE').sacred_sha['zh.js'])")
JA_ACTUAL=$(sha256sum frontend/src/i18n/locales/ja.js | awk '{print $1}')
ZH_ACTUAL=$(sha256sum frontend/src/i18n/locales/zh.js | awk '{print $1}')
if [ "$JA_ACTUAL" != "$JA_EXPECT" ]; then
  fail "G2: ja.js SHA drift — expected ${JA_EXPECT:0:16}… got ${JA_ACTUAL:0:16}…"
  echo "   intentional change? update .githooks/baseline.json then --no-verify"
fi
if [ "$ZH_ACTUAL" != "$ZH_EXPECT" ]; then
  fail "G2: zh.js SHA drift — expected ${ZH_EXPECT:0:16}… got ${ZH_ACTUAL:0:16}…"
  echo "   intentional change? update .githooks/baseline.json then --no-verify"
fi
[ "$JA_ACTUAL" = "$JA_EXPECT" ] && [ "$ZH_ACTUAL" = "$ZH_EXPECT" ] && ok "G2: sacred SHA match (ja, zh)"

# G5 — ko.js leaf count tolerance
if echo "$STAGED" | grep -qE 'frontend/src/i18n/locales/ko\.js'; then
  EXPECT=$(node -e "console.log(require('./$BASELINE').ko_leaf_count)")
  TOL_PCT=$(node -e "console.log(require('./$BASELINE').leaf_tolerance_pct)")
  ACTUAL=$(node -e "
    const fs=require('fs');const {parse}=require('acorn');
    const src=fs.readFileSync('frontend/src/i18n/locales/ko.js','utf8');
    const ast=parse(src,{ecmaVersion:'latest',sourceType:'module'});
    function obj(n){for(const b of n.body)if(b.type==='ExportDefaultDeclaration')return b.declaration;return null}
    function L(o){if(!o||o.type!=='ObjectExpression')return 0;let n=0;for(const p of o.properties){if(p.type!=='Property')continue;const v=p.value;if(v&&v.type==='ObjectExpression')n+=L(v);else n+=1}return n}
    console.log(L(obj(ast)));
  ")
  DELTA=$(( ACTUAL > EXPECT ? ACTUAL - EXPECT : EXPECT - ACTUAL ))
  MAX=$(( EXPECT * TOL_PCT / 100 ))
  if [ "$DELTA" -gt "$MAX" ]; then
    fail "G5: ko.js leaf count drift — expected $EXPECT actual $ACTUAL delta $DELTA > tol $MAX"
    echo "   intentional bulk change? update .githooks/baseline.json then --no-verify"
  else
    ok "G5: ko.js leaves $ACTUAL (Δ$DELTA ≤ $MAX)"
  fi
fi

# G6: i18n collision auto-check (Session 157 Step E-5)
# Bypass: TRIAGE_SKIP=1 git commit ...   (G6 only — G2/G5/B1-B4 still active)
if [ -n "$TRIAGE_SKIP" ]; then
  echo "⚠️  G6: skipped (TRIAGE_SKIP=$TRIAGE_SKIP)"
else
  STAGED_LOCALES=$(git diff --cached --name-only | grep -E '^frontend/src/i18n/locales/[^/]+\.js$' || true)
  if [ -n "$STAGED_LOCALES" ]; then
    G6_FAIL=0
    for f in $STAGED_LOCALES; do
      LOCALE_NAME=$(basename "$f" .js)
      if ! node tools/triage.mjs --locale "$LOCALE_NAME" --mode collision --quiet >/dev/null 2>&1; then
        EXIT=$?
        if [ $EXIT -eq 2 ]; then
          echo "❌ G6: $f failed to parse"
        else
          echo "❌ G6: $f has collisions (run: node tools/triage.mjs --locale $LOCALE_NAME --mode collision)"
        fi
        G6_FAIL=1
      else
        echo "  ✓ G6: $LOCALE_NAME collision-free"
      fi
    done
    if [ $G6_FAIL -eq 1 ]; then
      echo "❌ G6: collision gate failed"
      exit 1
    fi
    echo "✅ G6: staged locale collisions verified"
  fi
fi

# G9 — route registration consistency (Session 265)
#   routes.php $custom(정의)↔$register(등록) 2단계 불일치 = 런타임 "Not found"(404) 무음실패(php -l 미검출).
#   routes.php staged 시에만 실행. 우회: 의도적 미등록은 tools/check_routes_registered.mjs 의 ALLOW 등록.
if echo "$STAGED" | grep -qE '^backend/src/routes\.php$'; then
  if node tools/check_routes_registered.mjs backend/src/routes.php; then
    ok "G9: routes \$custom↔\$register 등록 정합"
  else
    fail "G9: routes.php 라우트 등록 정합 실패 — \$custom 정의 라우트에 \$register 누락(런타임 Not found)"
  fi
fi

# G10 — React rules-of-hooks + no-undef (Session 265 / 280차 확장)
#   조건부/early-return 뒤/try-catch 훅 = 화이트스크린 크래시(261/263 클래스). staged jsx 만 검사(고속).
#   [280차] no-undef 추가 — 미임포트/스코프밖 식별자는 vite build 를 통과하고 런타임 ReferenceError 로
#   터진다(PixelTracking useMemo 미임포트로 픽셀 관리 페이지가 276차부터 사망했던 부류).
#   의도적 예외는 소스에 // eslint-disable-next-line <rule> + 근거주석.
HOOKS_STAGED=$(echo "$STAGED" | grep -E '^frontend/src/.*\.(js|jsx)$' | sed 's#^frontend/##' || true)
if [ -n "$HOOKS_STAGED" ]; then
  if bash tools/check_rules_of_hooks.sh $HOOKS_STAGED; then
    ok "G10: react-hooks/rules-of-hooks + no-undef 정합"
  else
    fail "G10: rules-of-hooks/no-undef 위반(화이트스크린 위험) — 훅 상단이동·import 추가 또는 eslint-disable 근거명시"
  fi
fi

# G14 — 팬텀 정적자산 참조 (280차 신설)
#   코드가 로드/배포하는 루트 상대 정적파일(/pixel.js 등)이 frontend/public 에 실재하는지 검증.
#   ★nginx SPA 폴백이 index.html 을 200 으로 돌려주므로 404 조차 안 나고 기능이 조용히 죽는다
#   (280차: getSnippet 이 고객사에 배포한 /pixel.js 가 팬텀 → 픽셀 파이프라인 전체가 데이터 0).
#   vite build·eslint 전부 못 잡는 유일한 사각지대라 별도 가드가 필요하다.
REF_STAGED=$(echo "$STAGED" | grep -E '^(frontend/src|backend/src|frontend/public)/' || true)
if [ -n "$REF_STAGED" ]; then
  if node tools/check_static_refs.mjs; then
    ok "G14: 정적자산 참조 정합(팬텀 없음)"
  else
    fail "G14: 팬텀 정적자산 참조 — 파일 추가 또는 참조 경로 수정"
  fi
fi

# G11 — backend PHP syntax (Session 265)
#   php -l staged 백엔드 php(배포 전 구문오류 차단). php 미설치 시 non-blocking 스킵(CI 는 php 내장).
PHP_STAGED=$(echo "$STAGED" | grep -E '^backend/.*\.php$' || true)
if [ -n "$PHP_STAGED" ]; then
  if bash tools/check_php_lint.sh $PHP_STAGED; then
    ok "G11: 백엔드 php -l 구문 정합"
  else
    fail "G11: 백엔드 PHP 구문오류 — 배포 차단"
  fi
fi

# G12 — 채널 상품등록/수정 배선 회귀 가드 (277차 신설)
#   277차에 같은 클래스의 결함이 반복 신고됐다(필수 payload 누락·성공 오표기·카테고리 키 불일치·
#   상세/이미지 미전송·기존상품 수정 불가). 실 API 로 확정한 배선이 끊기면 여기서 즉시 차단한다.
CHWB_STAGED=$(echo "$STAGED" | grep -E '^(backend/src/Handlers/(Catalog|ChannelSync)\.php|frontend/src/pages/(PriceOpt|CatalogSync)\.jsx)$' || true)
if [ -n "$CHWB_STAGED" ]; then
  if node tools/guard_channel_writeback.mjs; then
    ok "G12: 채널 등록/수정 배선 정합"
  else
    fail "G12: 채널 등록/수정 배선 회귀 — 상품이 채널에 등록되지 않는 결함이 재발한다"
  fi
fi

# G13 — cron 러너 SSOT 정합 (279차 감사 J-P2)
#   backend/bin/*.php 러너 추가/변경 또는 install_crontab.sh 변경 시, 러너가 정본(install_crontab.sh)에 등록됐는지 검사.
#   미등록 시 신규서버/DR 에서 영원히 안 돎(media_gc 가 라이브엔 있으나 SSOT 누락이던 클래스). 우회는 check_cron_ssot.sh 의 ALLOW.
CRON_STAGED=$(echo "$STAGED" | grep -E '^backend/bin/.*\.php$|^backend/bin/install_crontab\.sh$' || true)
if [ -n "$CRON_STAGED" ]; then
  if bash backend/bin/check_cron_ssot.sh >/dev/null 2>&1; then
    ok "G13: cron 러너 install_crontab.sh SSOT 정합"
  else
    fail "G13: cron 러너가 install_crontab.sh 에 미등록 — DR/신규서버서 안 돎. 정본에 등록하거나 ALLOW 명시"
  fi
fi

# G15 — 헤더리스 getJson 인가 회귀 가드 (275차 신설 · 289차 배선)
#   275차에 가드 파일은 만들었으나 호출처가 0이라 이래로 한 번도 실행되지 않았다.
#   그 상태로 5-8/1-8/1-9 세 문서가 "CI 가드로 보호됨"을 전제했다 — 파일 존재가 검증을 대체한 사례.
#   헤더리스 getJson 은 운영에서 401 fail-closed → 조용한 빈 화면으로 나타난다(237차·275차 2회 재발).
HLGJ_STAGED=$(echo "$STAGED" | grep -E '^frontend/src/.*\.(jsx?|tsx?)$' || true)
if [ -n "$HLGJ_STAGED" ]; then
  if node tools/guard_headerless_getjson.mjs; then
    ok "G15: 헤더리스 getJson 인가 회귀 정합"
  else
    fail "G15: 헤더리스 getJson 회귀 — 인증 엔드포인트가 401 로 조용히 빈 화면이 된다"
  fi
fi

if [ "$FAIL" -ne 0 ]; then
  echo ""
  echo "Pre-commit blocked. Resolve issues or bypass with: git commit --no-verify (N-145-G)"
  exit 1
fi
ok "pre-commit gates pass"

# patch08 §3.2.2: self-test default-on (ko staged 시 aggregate 자동 invoke, TRIAGE_SELFTEST_SKIP=1 bypass)
# sacred ja/zh 는 G2 가드 영역. self-test 는 ko 회귀 검증 목적.
if [ -z "${TRIAGE_SELFTEST_SKIP:-}" ]; then
  if git diff --cached --name-only | grep -qE '^frontend/src/i18n/locales/ko\.js$'; then
    echo "[pre-commit] ko.js staged -> triage_apply_self_test_all.sh 자동 실행 (bypass: TRIAGE_SELFTEST_SKIP=1)"
    if ! bash tools/triage_apply_self_test_all.sh; then
      echo "[abort] self-test FAIL. commit 차단."
      exit 1
    fi
  fi
fi

# ─────────────────────────────────────────────────────────────
# G8-manifest-clean — Session 162
# ─────────────────────────────────────────────────────────────
# Trigger: ko.js or manifest builder staged
# Action: rebuild manifest v2 + verify parse_errors == 0
# Skip: SKIP=g8 (env), or neither trigger file staged
# ─────────────────────────────────────────────────────────────

if [[ "${SKIP:-}" == *"g8"* ]]; then
  echo "[G8] manifest-clean: SKIP (SKIP=g8)"
else
  G8_TRIGGER=""
  if git diff --cached --name-only | grep -qE '^(frontend/src/i18n/locales/ko\.js|tools/build_resolver_manifest_v2\.mjs)$'; then
    G8_TRIGGER="1"
  fi

  if [[ -n "$G8_TRIGGER" ]]; then
    if ! node tools/build_resolver_manifest_v2.mjs --emit-parse-errors --parse-errors-out /tmp/g8_parse_errors.json >/dev/null 2>&1; then
      echo "[G8] manifest-clean: builder FAILED ✗"
      echo "[G8] 재현 명령: node tools/build_resolver_manifest_v2.mjs --emit-parse-errors --parse-errors-out /tmp/g8_parse_errors.json"
      exit 1
    fi

    G8_PE_COUNT=$(node -e "const m=require('./tools/resolver_consumer_manifest_v2.json'); console.log((m.summary && typeof m.summary.parse_errors === 'number') ? m.summary.parse_errors : -1);" 2>/dev/null || echo "-1")

    if [[ "$G8_PE_COUNT" == "0" ]]; then
      echo "[G8] manifest-clean: parse_errors=0 ✓"
    else
      echo "[G8] manifest-clean: parse_errors=${G8_PE_COUNT} ✗"
      echo "[G8] FAIL — manifest v2 정밀도 회귀. 첫 10건:"
      (cat /tmp/g8_parse_errors.json 2>/dev/null | head -20 ; echo "") || echo "  (parse_errors_out 파일 없음 — 재현 명령 실행 필요)"
      echo "[G8] Mitigation:"
      echo "  1. parse_errors 파일 syntax 수정 후 재staged"
      echo "  2. 의도적 backup/legacy 디렉터리이면 SKIP_DIRS 동기 갱신"
      echo "  3. 우회 필요 시 SKIP=g8 git commit ... (비권장)"
      exit 1
    fi
  fi
fi

exit 0
