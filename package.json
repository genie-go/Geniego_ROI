{
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "e2e": "node tools/e2e/smoke.mjs",
    "e2e:render": "node tools/e2e/render.mjs",
    "e2e:scenario": "node tools/e2e/scenarios.mjs",
    "chatbot:kb": "node tools/gen_chatbot_knowledge.mjs",
    "nav:analyze": "node tools/navigation_analyze.mjs --snapshot",
    "nav:check": "node tools/navigation_analyze.mjs --quiet --fail-on=P1",
    "nav:test": "node tools/navigation_analyze_selftest.mjs",
    "nav:registry": "node tools/navigation_registry_build.mjs",
    "nav:registry:check": "node tools/navigation_registry_build.mjs --dry-run --quiet --fail-on=ERROR",
    "nav:context:test": "php backend/bin/navigation_context_selftest.php",
    "nav:all": "npm run nav:registry && npm run nav:test && npm run nav:registry:check && php backend/bin/navigation_registry.php selftest && php backend/bin/navigation_context_selftest.php"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "jquery": "^3.7.1",
    "summernote": "^0.8.20"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "acorn-walk": "^8.3.5",
    "astring": "^1.9.0",
    "path": "^0.12.7",
    "playwright": "^1.61.1",
    "ssh2": "^1.17.0",
    "vite": "^7.3.1"
  }
}
