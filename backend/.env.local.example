# ==============================================================================
# GeniegoROI — 로컬 개발 환경 설정 (협업자용)
# install.ps1 / install.sh 가 이 파일을 backend/.env 로 복사하고 APP_KEY 를 생성합니다.
# ★ MySQL 없이도 동작: 연결 실패 시 Db.php 가 자동으로 SQLite(data/genie_*.sqlite)로 폴백 +
#    첫 연결 시 전체 스키마를 자동 마이그레이션(멱등)합니다. → 즉시 구동 가능.
# ==============================================================================

APP_NAME="GenieGO_ROI_Local"
APP_ENV=development
APP_DEBUG=true
APP_KEY=                          # install 스크립트가 자동 생성(openssl rand -base64 32)
APP_TIMEZONE=UTC

# [DATABASE]
# 로컬 MySQL 이 있으면 아래 값을 맞추면 사용, 없으면 그대로 두면 SQLite 로 자동 폴백.
GENIE_ENV=production              # 로컬은 단일 환경(production) 권장 — 데모 분리 불필요
GENIE_DB_CONNECTION=mysql
GENIE_DB_HOST=127.0.0.1
GENIE_DB_PORT=3306
GENIE_DB_NAME=geniego_roi
GENIE_DB_USER=root
GENIE_DB_PASS=                    # 비워두면 MySQL 미설치 시 SQLite 폴백

# [BILLING — 로컬은 sandbox/비활성]
GENIE_BILLING_CURRENCY=USD
GENIE_BILLING_PROVIDER=paddle
GENIE_BILLING_METHOD=card_only
PADDLE_ENV=sandbox
PADDLE_CLIENT_TOKEN=
PADDLE_SECRET_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_SKIP_VERIFY=true           # 로컬 개발 한정(운영 절대 금지)

# [SECURITY — 로컬 CORS 는 index.php 가 localhost:5173 등 기본 허용]
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# [OPTIONAL — AI 기능 로컬 테스트 시 키 등록(없으면 폴백 동작)]
# CLAUDE_API_KEY=
LOG_LEVEL=debug
