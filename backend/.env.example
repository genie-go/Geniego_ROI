# ─────────────────────────────────────────────────────────────────────────────
# Paddle Billing v2 Configuration
# https://developer.paddle.com/getting-started/overview
# ─────────────────────────────────────────────────────────────────────────────

# Environment: "sandbox" (for testing) or "live" (for production)
PADDLE_ENV=sandbox

# Client-side token — safe to expose to the browser
# Paddle Dashboard > Developer Tools > Authentication > Client-side token
PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-side secret key — NEVER expose to frontend
# Paddle Dashboard > Developer Tools > Authentication > Secret key
PADDLE_SECRET_KEY=pdl_seck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret — from Paddle Dashboard > Notifications > endpoint detail
PADDLE_WEBHOOK_SECRET=pdch_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# Product Price IDs
# Paddle Dashboard > Catalog > Products > [product] > Prices
# Each price has a unique "pri_xxxx" ID for monthly and annual billing
# ─────────────────────────────────────────────────────────────────────────────
PADDLE_PRICE_STARTER_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_STARTER_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxx
PADDLE_PRICE_PRO_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────────────────────
# Database (MySQL on EC2)
# ─────────────────────────────────────────────────────────────────────────────
GENIE_DB_HOST=127.0.0.1
GENIE_DB_PORT=3306
GENIE_DB_NAME=geniego_roi
GENIE_DB_USER=root
GENIE_DB_PASS=your_db_password_here

# ─────────────────────────────────────────────────────────────────────────────
# Dev only — set to "true" to skip webhook signature verification
# NEVER set to true in production
# ─────────────────────────────────────────────────────────────────────────────
# PADDLE_SKIP_VERIFY=false
