# ==============================================================================
# GENIEGO ROI DATA PLATFORM - ENTERPRISE CONFIGURATION
# 목적: 결제 자동화, 마케팅 ROI 분석, 데이터 보안 및 고가용성 인프라 설정
# 관리자: 시스템 아키텍트 (System Architect)
# ==============================================================================

# [1. APPLICATION CORE - 시스템 기본 설정]
# ------------------------------------------------------------------------------
APP_NAME="GenieGO_ROI_Engine"
APP_ENV=production                # 실행 환경: development, staging, production
APP_KEY=                          # 보안 암호화 키 (예: openssl rand -base64 32)
APP_DEBUG=false                   # 운영 환경에서는 반드시 false (보안 핵심)
APP_URL=https://api.geniego.io    # API 서비스 도메인
APP_PORT=3000                     # 서비스 포트
APP_TIMEZONE=UTC                  # 분석 일관성을 위한 표준 시간대

# [2. PADDLE BILLING V2 - 글로벌 결제 게이트웨이]
# Paddle Dashboard > Developer Tools > Authentication 에서 확인
# ------------------------------------------------------------------------------
PADDLE_ENV=sandbox                # 테스트: sandbox, 실운영: live [cite: 1]
PADDLE_CLIENT_TOKEN=test_xxxxxxx  # 클라이언트 사이드 토큰 (브라우저 노출 가능) [cite: 1]
PADDLE_SECRET_KEY=pdl_seck_xxxx   # 서버 비밀키 (절대 노출 금지, RSA 암호화 대응) [cite: 1]
PADDLE_WEBHOOK_SECRET=pdch_xxxx   # 웹훅 서명 검증용 시크릿 (결제 조작 방지) [cite: 1]

# [3. STRATEGIC PRODUCT PRICE IDS - 마케팅 분석용 상품 ID]
# Paddle Dashboard > Catalog > Products > Prices 에서 생성된 ID 입력
# ------------------------------------------------------------------------------
# 각 ID는 마케팅 캠페인의 ROI(투자 대비 수익) 측정 및 전환율 분석의 기준점이 됩니다.
PADDLE_PRICE_STARTER_MONTHLY=pri_xxxx  # 스타터 플랜 월간 [cite: 1]
PADDLE_PRICE_STARTER_ANNUAL=pri_xxxx   # 스타터 플랜 연간 [cite: 1]
PADDLE_PRICE_PRO_MONTHLY=pri_xxxx      # 프로 플랜 월간 [cite: 1]
PADDLE_PRICE_PRO_ANNUAL=pri_xxxx       # 프로 플랜 연간 [cite: 1]
PADDLE_PRICE_ENTERPRISE_CUSTOM=pri_xxxx # 커스텀 엔터프라이즈 플랜

# [4. DATABASE - HIGH AVAILABILITY CLUSTER]
# Amazon EC2 / RDS (MySQL) 최적화 설정
# ------------------------------------------------------------------------------
GENIE_DB_CONNECTION=mysql
GENIE_DB_HOST=127.0.0.1           # DB 호스트 (Cluster Endpoint 권장) [cite: 1]
GENIE_DB_PORT=3306                # DB 포트 [cite: 1]
GENIE_DB_NAME=geniego_roi         # ROI 분석 데이터베이스 명칭 [cite: 1]
GENIE_DB_USER=root                # DB 계정 [cite: 1]
GENIE_DB_PASS=your_strong_pass    # DB 비밀번호 [cite: 1]

# 엔터프라이즈 성능 튜닝 (Connection Pooling)
GENIE_DB_MAX_CONNECTIONS=100      # 최대 동시 연결 수
GENIE_DB_IDLE_TIMEOUT=60          # 유휴 연결 해제 시간
GENIE_DB_SSL_MODE=verify-full     # 데이터 전송 암호화 (SSL/TLS)

# [5. LOGGING & MONITORING - 운영 관제 및 분석]
# ------------------------------------------------------------------------------
LOG_LEVEL=info                    # 로그 상세 수준 (error, warn, info, debug)
SENTRY_DSN=                       # 에러 추적 시스템 연동 (실시간 장애 감지)
GA_TRACKING_ID=                   # 구글 애널리틱스 ID (마케팅 기여도 추적)
MIXPANEL_TOKEN=                   # 사용자 행동 분석 및 퍼널 추적

# [6. SECURITY POLICY]
# ------------------------------------------------------------------------------
PADDLE_SKIP_VERIFY=false          # 웹훅 검증 스킵 여부 (운영환경에선 반드시 false) [cite: 2]
CORS_ALLOWED_ORIGINS=https://geniego.io,https://app.geniego.io

# ==============================================================================
# END OF CONFIGURATION
# ==============================================================================