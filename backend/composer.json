{
  "name": "genie/roi-enterprise-core",
  "description": "High-Performance ROI Analysis Backend for roi.genie-go.com",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "php-di/php-di": "^7.0",
    "vlucas/phpdotenv": "^5.5",
    "paddle/paddle-php-sdk": "^1.0",
    "illuminate/database": "^10.0",
    "monolog/monolog": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Genie\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}