# ─────────────────────────────────────────────────────────────────────────────
# Paddle Billing v2 — Frontend (Vite)
# These values are embedded into the built JS bundle — only expose public keys!
# ─────────────────────────────────────────────────────────────────────────────

# Environment: "sandbox" or "live"
VITE_PADDLE_ENV=sandbox

# Client-side token (safe to expose)
# Paddle Dashboard > Developer Tools > Authentication > Client-side token
VITE_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx

# Price IDs (from Paddle Dashboard > Catalog > Products > Prices)
VITE_PADDLE_PRICE_STARTER_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxx
VITE_PADDLE_PRICE_STARTER_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxx
VITE_PADDLE_PRICE_PRO_MONTHLY=pri_xxxxxxxxxxxxxxxxxxxx
VITE_PADDLE_PRICE_PRO_ANNUAL=pri_xxxxxxxxxxxxxxxxxxxx
