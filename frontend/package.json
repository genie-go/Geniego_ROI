{
  "name": "genie-roi-v407-ui",
  "private": true,
  "version": "407.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "sync:tokens": "node scripts/sync-css-tokens.cjs",
    "build:cap": "vite build --mode capacitor",
