    "@capacitor/ios": "^6.2.1",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "d3-geo": "^3.1.1",
    "dompurify": "^3.0.9",
    "hls.js": "^1.6.16",
    "isomorphic-dompurify": "^2.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.0",
    "ssh2-sftp-client": "^12.1.0",
    "topojson-client": "^3.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
